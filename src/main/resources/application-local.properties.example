# Copy this file to application-local.properties and fill in your values.
# application-local.properties is gitignored and loaded when you run with profile "local":
#   mvn spring-boot:run -Dspring-boot.run.profiles=local
#   or set SPRING_PROFILES_ACTIVE=local
#
# These override application.properties.

# AWS (optional if you prefer file over env vars)
# aws.access-key-id=your-access-key-id
# aws.secret-access-key=your-secret-access-key

# Example: override DB for local only
# spring.datasource.url=jdbc:mysql://localhost:3306/...
# spring.datasource.username=...
# spring.datasource.password=...

# Appels sortants vers l’API bancaire (RestClient) : toujours Authorization Bearer = app.remote-api.bearer-token
# app.remote-api.base-url=http://localhost:8080
# app.remote-api.bearer-token=<JWT service — ne pas commiter>
# GET comptes avec jeton service : nom du query param (ex. clientId, client_id). Vide = aucun param.
# app.remote-api.accounts-client-id-query-param=clientId
# En-tête optionnel pour l’ID client (ex. X-Client-Id) si l’API core l’exige.
# app.remote-api.accounts-client-id-header=X-Client-Id
# app.remote-api.current-account-product-code=CURR-STD-XAF
# app.remote-api.savings-account-product-code=SAV-STD-XAF
