# Modèle pour ~/docker-run-kozala-client.env sur l’EC2.
# Copier : cp docker-run-kozala-client.env.example docker-run-kozala-client.env puis éditer (ne pas commiter le .env rempli).
#
# Spring Boot : variables d’environnement (relaxed binding).

# --- Application / HTTP ---
SPRING_APPLICATION_NAME=kozala-client
SERVER_PORT=8082
SERVER_ADDRESS=0.0.0.0
SPRING_SERVLET_MULTIPART_MAX_FILE_SIZE=10MB
SPRING_SERVLET_MULTIPART_MAX_REQUEST_SIZE=25MB

# --- MySQL ---
SPRING_DATASOURCE_URL=jdbc:mysql://CHANGEME_RDS_HOST:3306/CHANGEME_DB?serverTimezone=UTC&useSSL=true
SPRING_DATASOURCE_USERNAME=CHANGEME_DB_USER
SPRING_DATASOURCE_PASSWORD=CHANGEME_DB_PASSWORD
SPRING_DATASOURCE_DRIVER_CLASS_NAME=com.mysql.cj.jdbc.Driver
SPRING_DATASOURCE_HIKARI_MAXIMUM_POOL_SIZE=15
SPRING_DATASOURCE_HIKARI_CONNECTION_TIMEOUT=30000
SPRING_DATASOURCE_HIKARI_IDLE_TIMEOUT=600000
SPRING_DATASOURCE_HIKARI_KEEPALIVE_TIME=30000

# --- JPA ---
SPRING_JPA_DATABASE_PLATFORM=org.hibernate.dialect.MySQLDialect
SPRING_JPA_HIBERNATE_DDL_AUTO=none
SPRING_JPA_SHOW_SQL=false

# --- JWT (≥ 32 caractères pour HS256) ---
JWT_SECRET=CHANGEME_MINIMUM_32_CHARS_RANDOM_SECRET_FOR_ACCESS_TOKEN
JWT_REFRESH_SECRET=CHANGEME_MINIMUM_32_CHARS_RANDOM_SECRET_FOR_REFRESH_TOKEN
JWT_ACCESS_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000

# --- Redis (service docker-compose : redis-kozala) ---
SPRING_DATA_REDIS_HOST=redis-kozala
SPRING_DATA_REDIS_PORT=6379
SPRING_DATA_REDIS_PASSWORD=
SPRING_DATA_REDIS_TIMEOUT=5000

# --- Actuator ---
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health
MANAGEMENT_ENDPOINT_HEALTH_SHOW_DETAILS=always

# --- Photos de profil (S3 uniquement sur EC2) ---
APP_PROFILE_PHOTO_REQUIRE_AWS_STORAGE=true
APP_PROFILE_PHOTO_MAX_SIZE_BYTES=5242880
APP_PROFILE_PHOTO_ALLOWED_CONTENT_TYPES=image/jpeg,image/png,image/webp

APP_FACE_VERIFICATION_PROVIDER=aws

# --- AWS : laisser vide sur EC2 si rôle IAM instance ; sinon clés dédiées (ne jamais commiter) ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_IDENTITY=CHANGEME_S3_BUCKET
AWS_REKOGNITION_FACE_MATCH_THRESHOLD=0.8

# --- API core banking ---
# Même EC2 que le core-backend : utiliser l’hôte Docker (pas le DNS public EC2 — souvent en échec depuis un conteneur).
# Après un "docker compose up" avec extra_hosts (host.docker.internal), par ex. :
#   APP_REMOTE_API_BASE_URL=http://host.docker.internal:8080
# Alternative si host.docker.internal indisponible : http://172.17.0.1:8080 (passerelle bridge Linux par défaut).
# Core sur une autre machine : URL réseau réelle, ex. http://autre-hote:8080
APP_REMOTE_API_BASE_URL=http://host.docker.internal:8080
APP_REMOTE_API_BEARER_TOKEN=CHANGEME_SERVICE_JWT
APP_REMOTE_API_CURRENT_ACCOUNT_PRODUCT_CODE=CURR-STD-XAF
APP_REMOTE_API_SAVINGS_ACCOUNT_PRODUCT_CODE=SAV-STD-XAF

#APP_REMOTE_API_ACCOUNTS_CLIENT_ID_QUERY_PARAM=clientId
#APP_REMOTE_API_ACCOUNTS_CLIENT_ID_HEADER=
